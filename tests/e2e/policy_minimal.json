{
  "bundle_version": 1,
  "issued_at": "2026-01-01T00:00:00Z",
  "expires_at": "2030-01-01T00:00:00Z",
  "policies": [
    {
      "id": "e2e-policy",
      "spec": {
        "selector": {
          "pathPrefix": "/",
          "methods": [
            "GET",
            "POST"
          ]
