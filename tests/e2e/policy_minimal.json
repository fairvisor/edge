            "algorithm": "token_bucket",
            "algorithm_config": {
              "tokens_per_second": 1,
              "burst": 2
            }
          }
        ]
      }
    }
  ],
  "kill_switches": [
    {
      "scope_key": "header:x-e2e-jitter",
      "scope_value": "on",
      "reason": "e2e_jitter_distribution"
    }
  ]
}
