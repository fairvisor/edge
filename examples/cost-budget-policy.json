{
  "bundle_version": 1,
  "issued_at": "2026-01-01T00:00:00Z",
  "expires_at": "2030-01-01T00:00:00Z",
  "policies": [
    {
      "id": "cost-budget-policy",
      "spec": {
        "selector": {
          "pathPrefix": "/v1/",
          "methods": ["POST"]
        },
        "mode": "enforce",
        "rules": [
          {
            "name": "5m-cost-window",
            "limit_keys": ["header:x-api-key"],
            "algorithm": "cost_based",
            "algorithm_config": {
              "budget": 5000,
              "period": "5m",
              "cost_key": "fixed",
              "fixed_cost": 1,
              "staged_actions": [
                { "threshold_percent": 80, "action": "warn" },
                { "threshold_percent": 95, "action": "throttle", "delay_ms": 200 },
                { "threshold_percent": 100, "action": "reject" }
              ]
            }
          }
        ]
      }
    }
  ],
  "kill_switches": []
}
