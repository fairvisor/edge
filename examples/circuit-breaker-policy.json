{
  "bundle_version": 1,
  "issued_at": "2026-01-01T00:00:00Z",
  "expires_at": "2030-01-01T00:00:00Z",
  "policies": [
    {
      "id": "circuit-breaker-policy",
      "spec": {
        "selector": {
          "pathPrefix": "/v1/",
          "methods": ["POST"]
        },
        "mode": "enforce",
        "rules": [
          {
            "name": "per-tenant-budget",
            "limit_keys": ["jwt:org_id"],
            "algorithm": "cost_based",
            "algorithm_config": {
              "budget": 10000,
              "period": "1h",
              "cost_key": "fixed",
              "fixed_cost": 1,
              "staged_actions": [
                { "threshold_percent": 100, "action": "reject" }
              ]
            }
          }
        ],
        "circuit_breaker": {
          "enabled": true,
          "spend_rate_threshold_per_minute": 1000,
          "action": "reject",
          "alert": true,
          "auto_reset_after_minutes": 5
        }
      }
    }
  ],
  "kill_switches": []
}
